# ============================================
# WALMART REAL ESTATE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ============= SECURITY =============
# JWT Secret - Generate a strong random string (minimum 64 characters)
# Example: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long

# Environment: development | production
NODE_ENV=development

# ============= SERVER =============
# Server port (default: 3000)
PORT=3000

# Allowed origins for CORS (comma-separated)
# Example: https://walmartrealty.github.io,https://yourdomain.com
ALLOWED_ORIGINS=https://walmartrealty.github.io

# ============= EMAIL (Optional) =============
# SMTP configuration for LOI notifications
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@walmart.com
SMTP_PASS=your-email-password
SMTP_FROM=realestate@walmart.com

# ============= DATABASE =============
# SQLite database path (default: ./walmart-realty.db)
DATABASE_PATH=./walmart-realty.db

# ============= ADMIN =============
# Initial admin credentials (only used on first run)
# Change the password immediately after first login!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!@#

# ============= LOGGING =============
# Log level: debug | info | warn | error
LOG_LEVEL=info
